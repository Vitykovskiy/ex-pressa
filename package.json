{
  "name": "ex-pressa",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "run-p client:dev server:dev",
    "client:dev": "npm run dev -w client",
    "client:build": "npm run build -w client",
    "client:lint": "npm run lint -w client",
    "client:preview": "npm run preview -w client",
    "server:dev": "npm run start:dev -w server",
    "server:start": "npm run start -w server",
    "server:build": "npm run build -w server",
    "server:lint": "npm run lint -w server",
    "server:test": "npm run test -w server",
    "build": "npm run server:build && npm run client:build",
    "lint": "npm run server:lint && npm run client:lint"
  },
  "devDependencies": {
    "npm-run-all2": "^8.0.4"
  }
}
